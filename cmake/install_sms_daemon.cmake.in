file(MAKE_DIRECTORY "$ENV{DESTDIR}@SMS_DAEMON_CONFIG_DIR@")
if(NOT EXISTS "$ENV{DESTDIR}@SMS_DAEMON_CONFIG_FILE@")
    configure_file("@SMS_DAEMON_CONFIG_SRC@" "$ENV{DESTDIR}@SMS_DAEMON_CONFIG_FILE@" COPYONLY)
else()
    message(STATUS "keep existing $ENV{DESTDIR}@SMS_DAEMON_CONFIG_FILE@")
endif()

file(MAKE_DIRECTORY "$ENV{DESTDIR}/tmp/sms-daemon")
file(MAKE_DIRECTORY "$ENV{DESTDIR}/tmp/sms-daemon/outsms")
file(MAKE_DIRECTORY "$ENV{DESTDIR}/tmp/sms-daemon/ReceivedSMS")
